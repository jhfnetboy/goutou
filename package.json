{
  "name": "seeder",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hostable project management workspace built on Cloudflare Workers, D1, and R2.",
  "license": "MIT",
  "author": "Daniel Syauqi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danielsyauqi/Seeder.git"
  },
  "homepage": "https://github.com/danielsyauqi/Seeder#readme",
  "bugs": {
    "url": "https://github.com/danielsyauqi/Seeder/issues"
  },
  "keywords": [
    "project-management",
    "kanban",
    "nextjs",
    "cloudflare-workers",
    "d1",
    "r2",
    "self-hostable"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy -- --keep-vars",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "db:migrate:local": "wrangler d1 migrations apply PM_DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply PM_DB --remote",
    "db:seed:local": "bun run scripts/seed.ts",
    "db:slugs:local": "bun run scripts/backfill-project-slugs.ts"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.9",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@phosphor-icons/react": "^2.1.10",
    "@tiptap/extension-image": "^3.23.5",
    "@tiptap/extension-link": "^3.23.5",
    "@tiptap/extension-placeholder": "^3.23.5",
    "@tiptap/extension-table": "^3.23.5",
    "@tiptap/extension-table-cell": "^3.23.5",
    "@tiptap/extension-table-header": "^3.23.5",
    "@tiptap/extension-table-row": "^3.23.5",
    "@tiptap/pm": "^3.23.5",
    "@tiptap/react": "^3.23.5",
    "@tiptap/starter-kit": "^3.23.5",
    "better-auth": "^1.6.9",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-activity-calendar": "^2.7.15",
    "react-dom": "19.2.4",
    "recharts": "^2.15.4",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.4",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8",
    "wrangler": "^4.86.0"
  }
}
